# Supabase — copy this file to `.env.local` and fill in the two values from
# your Supabase project (Project Settings → API). `.env.local` is git-ignored.
# The anon/public key is safe to expose to the browser; never put the
# service_role key in a NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
